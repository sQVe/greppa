{
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "bracketSpacing": true,
  "arrowParens": "always",
  "ignore": ["dist/**", "coverage/**"],
  "sortImports": {
    "newlinesBetween": true,
    "groups": [
      "builtin",
      ["@greppa", "external"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ],
    "customGroups": [
      {
        "groupName": "@greppa",
        "elementNamePattern": ["@greppa/**"]
      }
    ]
  }
}
